# Salin file ini jadi "keystore.properties" (tanpa .example) lalu isi
# password aslinya. JANGAN commit keystore.properties atau file .jks
# ke git/GitHub — ini rahasia untuk menandatangani APK kamu sendiri.
storePassword=ISI_PASSWORD_KEYSTORE
keyPassword=ISI_PASSWORD_KEY
keyAlias=potato-monitor-desk
storeFile=app/release-keystore.jks
